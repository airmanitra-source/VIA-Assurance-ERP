@using ClientApp.Models
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<ClientApp.SharedResource> Localizer

<div class="section">
    <h2>📝 @Localizer["PaySlipVariables"]</h2>
    <div class="form-row">
        <div class="form-group">
            <label>Bonus</label>
            <input type="number" class="form-input" step="0.01" @bind="PaySlipInput.Bonus" />
        </div>
        <div class="form-group">
            <label>@Localizer["SchoolAllowance"]</label>
            <input type="number" class="form-input" step="0.01" @bind="PaySlipInput.PrimeScolarite" />
        </div>
        <div class="form-group">
            <label>13ème mois</label>
            <input type="number" class="form-input" step="0.01" @bind="PaySlipInput.TreiziemeMois" />
        </div>
    </div>
    <div class="form-row">
        <div class="form-group">
            <label>@Localizer["TransportAllowance"]</label>
            <input type="number" class="form-input" step="0.01" @bind="PaySlipInput.IndemniteTransport" />
        </div>
        <div class="form-group">
            <label>@Localizer["HousingAllowance"]</label>
            <input type="number" class="form-input" step="0.01" @bind="PaySlipInput.IndemniteLogement" />
        </div>
        <div class="form-group">
            <label>@Localizer["OvertimeHours"]</label>
            <input type="number" class="form-input" step="0.5" @bind="PaySlipInput.OvertimeHours" />
        </div>
    </div>
    <div class="form-row">
        <div class="form-group" style="align-self: end;">
            <button class="btn-primary" @onclick="OnGenerateClick" disabled="@IsGenerating">
                @(IsGenerating ? "⏳" : "") @(ButtonLabel ?? Localizer["GeneratePaySlip"])
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public PaySlipInputViewModel PaySlipInput { get; set; } = default!;

    [Parameter]
    public string? ButtonLabel { get; set; }

    [Parameter]
    public bool IsGenerating { get; set; }

    [Parameter]
    public EventCallback OnGenerateClick { get; set; }
}
