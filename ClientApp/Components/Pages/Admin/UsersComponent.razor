@page "/admin/users"
@inherits AuthenticatedComponentBase
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "developer")]
@rendermode InteractiveServer
@using ClientApp.Services
@using ClientApp.Components.Shared
@using FileTable.Infrastructure.Identities
@using Microsoft.AspNetCore.Identity

<PageTitle>@Localizer["UserManagement"] - ERP ASSUR</PageTitle>

<div class="admin-users-container">
    <div class="page-header">
        <div class="header-content">
            <h1>🛠️ User Management</h1>
            <p>@Localizer["ManageUsers"]</p>
        </div>
        <button class="btn-primary" @onclick="OpenAddUserModal" disabled="@isLoading">
            ➕ Add New User
        </button>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <div class="alert alert-danger">
            @errorMessage
            <button class="btn-close-alert" @onclick='() => errorMessage = ""'>&times;</button>
        </div>
    }

    @if (isLoading)
    {
        <div class="loading-state">
            <span class="spinner"></span>
            <p>Loading users...</p>
        </div>
    }
    else
    {
        <div class="users-grid">
            <table class="users-table">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Enterprise Name</th>
                        <th>Roles</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in users)
                    {
                        <tr>
                            <td>@user.Email</td>
                            <td>@user.RaisonSocial</td>
                            <td>
                                @if (userRoles.ContainsKey(user.Id))
                                {
                                    @foreach (var role in userRoles[user.Id])
                                    {
                                        <span class="role-badge">@role</span>
                                    }
                                }
                                else
                                {
                                    <span class="text-muted">No roles</span>
                                }
                            </td>
                            <td>
                                <div class="action-buttons">
                                    <button class="btn-sm btn-info" @onclick="() => OpenRoleModalAsync(user)">
                                        🔐 Manage Roles
                                    </button>
                                    <button class="btn-sm btn-danger" @onclick="() => OpenConfirmDeleteModal(user)" disabled="@isProcessing">
                                        ❌ Inactivate
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@* Add User Modal *@
@if (showAddUserModal)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Add New User</h3>
                <button class="btn-close" @onclick="CloseAddUserModal" disabled="@isProcessing">&times;</button>
            </div>

            <div class="modal-body">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">
                        @errorMessage
                    </div>
                }

                <form>
                    <div class="form-group">
                        <label for="role">User Role <span class="required">*</span></label>
                        <select id="role" class="form-control" 
                                value="@addUserSelectedRole"
                                @onchange="OnRoleChangedAsync"
                                disabled="@isProcessing">
                            <option value="">-- Select Role --</option>
                            @foreach (var role in allRoles)
                            {
                                <option value="@role">@role</option>
                            }
                        </select>
                    </div>

                    @if (addUserSelectedRole == "employee")
                    {
                        <div class="form-group">
                            <label for="employeeSelect">Select Employee <span class="required">*</span></label>
                            @if (availableEmployees.Count > 0)
                            {
                                <select id="employeeSelect" class="form-control" 
                                        @bind="addUserSelectedEmployeeId"
                                        disabled="@isProcessing">
                                    <option value="0">-- Select Employee --</option>
                                    @foreach (var emp in availableEmployees)
                                    {
                                        <option value="@emp.EmployeeID">@emp.Prenom @emp.Nom (@emp.Email)</option>
                                    }
                                </select>
                            }
                            else
                            {
                                <div class="alert alert-info">
                                    <p><strong>No employees available</strong></p>
                                    <p>All employees either:</p>
                                    <ul style="margin: 0.5rem 0; padding-left: 1.5rem;">
                                        <li>Don't have email addresses, OR</li>
                                        <li>Already have user accounts, OR</li>
                                        <li>Have completed their initial password reset</li>
                                    </ul>
                                </div>
                            }
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(addUserSelectedRole))
                    {
                        <div class="form-group">
                            <label for="email">Email <span class="required">*</span></label>
                            <input type="email" id="email" class="form-control" 
                                   @bind="addUserEmail" 
                                   disabled="@isProcessing"
                                   placeholder="user@example.com" />
                        </div>
                    }

                    <div class="form-group">
                        <label>
                            <input type="checkbox" @bind="useDefaultPassword" disabled="@isProcessing" />
                            Use default password (user must reset via email)
                        </label>
                    </div>

                    @if (!useDefaultPassword)
                    {
                        <div class="form-group">
                            <label for="password">Password <span class="required">*</span></label>
                            <input type="password" id="password" class="form-control" 
                                   @bind="addUserPassword" 
                                   disabled="@isProcessing"
                                   placeholder="Enter password (min 6 characters)" />
                        </div>

                        <div class="form-group">
                            <label for="confirmPassword">Confirm Password <span class="required">*</span></label>
                            <input type="password" id="confirmPassword" class="form-control" 
                                   @bind="addUserConfirmPassword" 
                                   disabled="@isProcessing"
                                   placeholder="Confirm password" />
                            @if (!string.IsNullOrEmpty(addUserPassword) && !string.IsNullOrEmpty(addUserConfirmPassword) && addUserPassword != addUserConfirmPassword)
                            {
                                <small class="form-text-error">Passwords do not match</small>
                            }
                        </div>
                    }
                </form>
            </div>

            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseAddUserModal" disabled="@isProcessing">
                    Cancel
                </button>
                <button class="btn-primary" @onclick="CreateUserAsync" disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                    }
                    Create User
                </button>
            </div>
        </div>
    </div>
}

@* Manage Roles Modal *@
@if (showRoleModal && selectedUser != null)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <div class="modal-header">
                <h3>Manage Roles for @selectedUser.Email</h3>
                <button class="btn-close" @onclick="CloseRoleModal">&times;</button>
            </div>

            <div class="modal-body">
                <p class="user-info">@selectedUser.RaisonSocial</p>
                
                <div class="roles-list">
                    @foreach (var role in allRoles)
                    {
                        <div class="role-item">
                            <label>
                                <input type="checkbox" 
                                       checked="@(selectedUserRoles.Contains(role))" 
                                       @onchange="@(e => ToggleRoleAsync(role, e.Value))" />
                                @role
                            </label>
                        </div>
                    }
                </div>
            </div>

            <div class="modal-footer">
                <button class="btn-primary" @onclick="CloseRoleModal">Close</button>
            </div>
        </div>
    </div>
}

@* Confirm Delete Modal *@
@if (showConfirmDeleteModal && pendingDeleteUser != null)
{
    <div class="modal-overlay">
        <div class="modal-content modal-content-sm">
            <div class="modal-header">
                <h3>Confirm Inactivation</h3>
                <button class="btn-close" @onclick="CloseConfirmDeleteModal" disabled="@isProcessing">&times;</button>
            </div>

            <div class="modal-body">
                <p>Are you sure you want to inactivate <strong>@pendingDeleteUser.Email</strong>?</p>
                <p class="text-warning">This action cannot be easily undone.</p>
            </div>

            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseConfirmDeleteModal" disabled="@isProcessing">
                    Cancel
                </button>
                <button class="btn-danger" @onclick="ConfirmInactivateUserAsync" disabled="@isProcessing">
                    @if (isProcessing)
                    {
                        <span class="spinner-border spinner-border-sm"></span>
                    }
                    Inactivate User
                </button>
            </div>
        </div>
    </div>
}
