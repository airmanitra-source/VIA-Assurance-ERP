@page "/admin/users"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "developer")]
@rendermode InteractiveServer
@using ClientApp.Services
@using FileTable.Infrastructure.Identities
@using Microsoft.AspNetCore.Identity

<PageTitle>@Localizer["UserManagement"] - VIA Assurance</PageTitle>

<div class="admin-users-container">
    <div class="page-header">
        <h1>🛠️ @Localizer["UserSettings"]</h1>
        <p>@Localizer["ManageUsers"]</p>
    </div>

    @if (isLoading)
    {
        <div class="loading-state">
            <span class="spinner"></span>
            <p>Loading users...</p>
        </div>
    }
    else
    {
        <div class="users-grid">
            <table class="users-table">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Enterprise Name</th>
                        <th>Roles</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in users)
                    {
                        <tr>
                            <td>@user.Email</td>
                            <td>@user.RaisonSocial</td>
                            <td>
                                @if (userRoles.ContainsKey(user.Id))
                                {
                                    @foreach (var role in userRoles[user.Id])
                                    {
                                        <span class="role-badge">@role</span>
                                    }
                                }
                            </td>
                            <td>
                                <button class="btn-sm" @onclick="() => OpenRoleModalAsync(user)">Manage Roles</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@if (showRoleModal && selectedUser != null)
{
    <div class="modal-overlay">
        <div class="modal-content">
            <h3>Manage Roles for @selectedUser.RaisonSocial</h3>
            <p>@selectedUser.Email</p>
            
            <div class="roles-list">
                @foreach (var role in allRoles)
                {
                    <div class="role-item">
                        <label>
                            <input type="checkbox" 
                                   checked="@(selectedUserRoles.Contains(role))" 
                                   @onchange="@(e => ToggleRoleAsync(role, e.Value))" />
                            @role
                        </label>
                    </div>
                }
            </div>

            <div class="modal-actions">
                <button class="btn-primary" @onclick="CloseModal">Close</button>
            </div>
        </div>
    </div>
}
