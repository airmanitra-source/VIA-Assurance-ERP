@page "/reset-password"
@rendermode InteractiveServer
@using System.Web

<PageTitle>Reset Password - VIA Assurance</PageTitle>

<div class="reset-password-container">
    <div class="reset-password-card">
        <div class="header">
            <h1>🔐 Reset Your Password</h1>
            <p>Enter your new password to activate your account</p>
        </div>

        @if (isLoading)
        {
            <div class="loading-state">
                <span class="spinner"></span>
                <p>Validating reset link...</p>
            </div>
        }
        else if (isInvalidToken)
        {
            <div class="error-state">
                <div class="error-icon">❌</div>
                <h2>Invalid Reset Link</h2>
                <p>@errorMessage</p>
                <p class="hint">Reset links expire after 24 hours. Please request a new password reset link.</p>
                <button class="btn-primary" @onclick="NavigateToLogin">Back to Login</button>
            </div>
        }
        else if (passwordResetSuccess)
        {
            <div class="success-state">
                <div class="success-icon">✅</div>
                <h2>Password Reset Successful</h2>
                <p>@successMessage</p>
                <p class="redirect-message">Redirecting to login page...</p>
                <button class="btn-primary" @onclick="NavigateToLogin">Go to Login Now</button>
            </div>
        }
        else
        {
            <form @onsubmit="HandleResetAsync" class="reset-form">
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="alert alert-danger">
                        @errorMessage
                        <button type="button" class="btn-close-alert" @onclick='() => errorMessage = ""'>&times;</button>
                    </div>
                }

                <div class="form-group">
                    <label for="defaultPassword">Default Password</label>
                    <input type="password" 
                           id="defaultPassword" 
                           class="form-control" 
                           @bind="defaultPasswordInput"
                           disabled="@isProcessing"
                           placeholder="Enter the default password from the email"
                           required />
                </div>

                <div class="form-group">
                    <label for="newPassword">New Password</label>
                    <input type="password" 
                           id="newPassword" 
                           class="form-control" 
                           @bind="newPassword"
                           disabled="@isProcessing"
                           placeholder="Enter new password (minimum 6 characters)"
                           required />
                </div>

                <div class="form-group">
                    <label for="confirmPassword">Confirm Password</label>
                    <input type="password" 
                           id="confirmPassword" 
                           class="form-control" 
                           @bind="confirmPassword"
                           disabled="@isProcessing"
                           placeholder="Confirm new password"
                           required />
                    @if (!string.IsNullOrEmpty(newPassword) && !string.IsNullOrEmpty(confirmPassword) && newPassword != confirmPassword)
                    {
                        <small class="form-text-error">Passwords do not match</small>
                    }
                    @if (!string.IsNullOrEmpty(newPassword) && newPassword.Length < 6)
                    {
                        <small class="form-text-error">Password must be at least 6 characters</small>
                    }
                </div>

                <div class="form-info">
                    <p><strong>Password Requirements:</strong></p>
                    <ul>
                        <li>Enter the default password provided in the reset email</li>
                        <li>Choose a new password at least 6 characters long</li>
                        <li>Contains uppercase and lowercase letters</li>
                        <li>Contains numbers</li>
                    </ul>
                </div>

                <div class="button-group">
                    <button type="submit" 
                            class="btn-primary" 
                            disabled="@(isProcessing || newPassword != confirmPassword || newPassword.Length < 6)">
                        @if (isProcessing)
                        {
                            <span class="spinner-border spinner-border-sm"></span>
                        }
                        Reset Password
                    </button>
                    <button type="button" 
                            class="btn-secondary" 
                            @onclick="NavigateToLogin"
                            disabled="@isProcessing">
                        Back to Login
                    </button>
                </div>
            </form>
        }

        <div class="footer">
            <p>Questions? Contact support at <strong>airmanitra@gmail.com</strong></p>
        </div>
    </div>
</div>
