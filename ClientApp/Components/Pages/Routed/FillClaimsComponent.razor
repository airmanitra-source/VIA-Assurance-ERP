@page "/fill-claims"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "developer")]
@rendermode InteractiveServer
@using ClientApp.Models
@using ClientApp.Services
@using Company.Fleet.Module
@using Company.Transportation.Module
@using Company.Warehouse.Module
@using Company.Module
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms
@inject Microsoft.Extensions.Localization.IStringLocalizer<SharedResource> Localizer

<PageTitle>@Localizer["FillClaim"] - Ny Havana Dashboard</PageTitle>

<div class="fill-claims-container">
    <div class="fill-claims-card">
        <div class="header">
            <h1>📋 @Localizer["FillClaim"]</h1>
            <p>@Localizer["ReportIncidentOrDamage"]</p>
        </div>

        @if (isLoadingCompany || isLoadingAssets)
        {
            <div class="loading-state">
                <span class="spinner"></span>
                <p>@Localizer["Loading"]...</p>
            </div>
        }
        else if (currentCompany == null)
        {
            <div class="error-list">
                <div class="error-message">⚠️ @Localizer["CouldNotRetrieveEnterprise"]</div>
            </div>
            <button class="btn-back" @onclick='() => Navigation.NavigateTo("/login")'>@Localizer["BackToLogin"]</button>
        }
        else
        {
            <div class="enterprise-info">
                <span>@Localizer["Enterprise"]: <strong>@currentCompany.RaisonSocial</strong></span>
            </div>

            <EditForm Model="@sinisterModel" OnValidSubmit="@HandleSubmit" class="claims-form">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <!-- Asset Type Selection -->
                <div class="form-group">
                    <label for="assetType">@Localizer["SelectAssetType"] *</label>
                    <InputSelect id="assetType" @bind-Value="selectedAssetType" @onchange="OnAssetTypeChanged" class="form-input">
                        <option value="">-- @Localizer["Select"] --</option>
                        <option value="Fleet">@Localizer["AutomobileFleet"]</option>
                        <option value="Transportation">@Localizer["GoodsTransportation"]</option>
                        <option value="Warehouse">@Localizer["Warehouse"]</option>
                    </InputSelect>
                    @if (string.IsNullOrEmpty(selectedAssetType))
                    {
                        <div class="validation-error">@Localizer["AssetTypeRequired"]</div>
                    }
                </div>

                <!-- Asset Selection -->
                @if (!string.IsNullOrEmpty(selectedAssetType))
                {
                    <div class="form-group">
                        <label for="asset">@Localizer["SelectAsset"] *</label>
                        <InputSelect id="asset" @bind-Value="selectedAssetId" class="form-input">
                            <option value="0">-- @Localizer["Select"] --</option>
                            @if (selectedAssetType == "Fleet")
                            {
                                @foreach (var fleet in fleets)
                                {
                                    <option value="@fleet.Id">@fleet.Make @fleet.Model (@fleet.Year) - @fleet.Type</option>
                                }
                            }
                            else if (selectedAssetType == "Transportation")
                            {
                                @foreach (var transport in transportations)
                                {
                                    <option value="@transport.Id">@transport.Description (@transport.Origin → @transport.Destination)</option>
                                }
                            }
                            else if (selectedAssetType == "Warehouse")
                            {
                                @foreach (var warehouse in warehouses)
                                {
                                    <option value="@warehouse.Id">@warehouse.Name - @warehouse.SizeM2 m²</option>
                                }
                            }
                        </InputSelect>
                        @if (selectedAssetId == 0)
                        {
                            <div class="validation-error">@Localizer["AssetRequired"]</div>
                        }
                    </div>
                }

                <!-- Sinister Date -->
                <div class="form-row">
                    <div class="form-group">
                        <label for="sinisterDate">@Localizer["IncidentDate"] *</label>
                        <InputDate id="sinisterDate" @bind-Value="sinisterModel.SinisterDate" class="form-input" />
                        <ValidationMessage For="@(() => sinisterModel.SinisterDate)" />
                    </div>
                </div>

                <!-- Sinister Types -->
                @if (!string.IsNullOrEmpty(selectedAssetType))
                {
                    <div class="form-group">
                        <label>@Localizer["SinisterType"] *</label>
                        <div class="tags-container">
                            @if (availableSinisterTypes.Any())
                            {
                                @foreach (var type in availableSinisterTypes)
                                {
                                    <button type="button" 
                                            class="@(IsSinisterTypeSelected(type.Id) ? "tag tag-selected" : "tag")"
                                            @onclick="() => ToggleSinisterType(type.Id)">
                                        @type.TypeName
                                    </button>
                                }
                            }
                            else
                            {
                                <p class="no-types">@Localizer["NoSinisterTypesAvailable"]</p>
                            }
                        </div>
                        @if (!selectedSinisterTypeIds.Any())
                        {
                            <div class="validation-error">@Localizer["SinisterTypeRequired"]</div>
                        }
                    </div>
                }

                <!-- Description -->
                <div class="form-group">
                    <label for="description">@Localizer["Description"] *</label>
                    <InputTextArea id="description" @bind-Value="sinisterModel.Description" class="form-input" placeholder="@Localizer["DescribeIncident"]" rows="5" />
                    <ValidationMessage For="@(() => sinisterModel.Description)" />
                </div>

                <div class="documents-section">
                    <h3>📷 Photo de l'accident</h3>

                    @if (attachedDocuments.Any())
                    {
                        <div class="document-list">
                            @foreach (var doc in attachedDocuments)
                            {
                                <div class="document-item">
                                    <div class="document-info">
                                        <span class="document-icon">📷</span>
                                        <span class="document-name">@doc.Name</span>
                                    </div>
                                    <button type="button" class="btn-remove" @onclick="() => RemoveDocument(doc)">✕</button>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <p class="no-documents">Aucune photo ajoutée.</p>
                    }

                    <div class="document-add-row">
                        <div class="form-group">
                            <label>Ajouter une photo</label>
                            <InputFile OnChange="OnPhotoSelected" class="form-input file-input" accept="image/*" />
                        </div>
                    </div>
                </div>

                <!-- Amounts -->
                <div class="form-row">
                    <div class="form-group">
                        <label for="estimatedAmount">@Localizer["EstimatedAmount"] *</label>
                        <InputNumber id="estimatedAmount" @bind-Value="sinisterModel.EstimatedAmount" class="form-input" />
                        <ValidationMessage For="@(() => sinisterModel.EstimatedAmount)" />
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="form-actions">
                    <button type="submit" class="btn-submit" disabled="@isSubmitting">
                        @if (isSubmitting)
                        {
                            <span>@Localizer["Submitting"]...</span>
                        }
                        else
                        {
                            <span>📝 @Localizer["SubmitClaim"]</span>
                        }
                    </button>
                    <button type="button" class="btn-cancel" @onclick='() => Navigation.NavigateTo("")'>
                        ❌ @Localizer["Cancel"]
                    </button>
                </div>
            </EditForm>

            @if (!string.IsNullOrEmpty(successMessage))
            {
                <div class="success-message">
                    ✅ @successMessage
                </div>
            }

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="error-message">
                    ⚠️ @errorMessage
                </div>
            }
        }
    </div>
</div>
