@page "/employee-documents"
@inherits AuthenticatedComponentBase
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize(Roles = "directeur,RH,auditeur,admin,developer")]
@rendermode InteractiveServer
@using ClientApp.Models
@using ClientApp.Services
@using ClientApp.Components
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Web

<PageTitle>Documents - VIA Assurance Dashboard</PageTitle>

<div class="document-explorer">
    <div class="header">
        <div class="header-left">
            <h1>🛡️ @Localizer["DocumentsTitle"]</h1>
            <span class="user-badge">👤 @CurrentUserEmail</span>
        </div>
        <div class="header-actions">
            <button class="btn btn-primary" @onclick="RefreshTreeAsync">
                🔄 Refresh
            </button>
            <button class="btn btn-secondary" @onclick="HandleLogoutAsync">
                🚪 Logout
            </button>
        </div>
    </div>

    <div class="explorer-container">
        <div class="tree-panel">
            <h3>@Localizer["DocumentTreeTitle"]</h3>
            @if (isLoading)
            {
                <div class="loading">
                    <div class="spinner"></div>
                    <p>@Localizer["LoadingDocuments"]</p>
                </div>
            }
            else if (documentTree != null && documentTree.Any())
            {
                <div class="tree-view">
                    @foreach (var node in documentTree)
                    {
                        <TreeViewNode Node="node" OnNodeSelected="HandleNodeSelected" IsSelected="selectedNode == node" SelectedNode="selectedNode" />
                    }
                </div>
            }
            else
            {
                <div class="empty-state">
                    <p>@Localizer["NoDocumentsFound"]</p>
                </div>
            }
        </div>

        <div class="details-panel">
            @if (selectedNode != null)
            {
                <div class="details-tabs">
                    <button class="tab-button @(activeTab == "preview" ? "active" : "")" @onclick='() => activeTab = "preview"'>
                        👁️ Preview
                    </button>
                    <button class="tab-button @(activeTab == "details" ? "active" : "")" @onclick='() => activeTab = "details"'>
                        ℹ️ Details
                    </button>
                </div>

                @if (activeTab == "preview")
                {
                    <div class="tab-content">
                        <EmployeeDocumentPreview Document="selectedNode" @key="selectedNode.StreamId" />
                    </div>
                }
                else
                {
                    <div class="tab-content">
                        <div class="details-content">
                            <div class="detail-group">
                                <h4>@Localizer["BasicInfoTitle"]</h4>
                                <table class="details-table">
                                    <tr>
                                        <td class="label">Name:</td>
                                        <td class="value">@selectedNode.Name</td>
                                    </tr>
                                    <tr>
                                        <td class="label">Type:</td>
                                        <td class="value">@(selectedNode.IsDirectory ? "Directory" : "File")</td>
                                    </tr>
                                    @if (!string.IsNullOrEmpty(selectedNode.FileType))
                                    {
                                        <tr>
                                            <td class="label">File Type:</td>
                                            <td class="value">@selectedNode.FileType</td>
                                        </tr>
                                    }
                                    @if (!selectedNode.IsDirectory && selectedNode.CachedFileSize.HasValue)
                                    {
                                        <tr>
                                            <td class="label">Size:</td>
                                            <td class="value">@selectedNode.SizeDisplay (@selectedNode.CachedFileSize.Value bytes)</td>
                                        </tr>
                                    }
                                </table>
                            </div>

                            <div class="detail-group">
                                <h4>@Localizer["TimestampsTitle"]</h4>
                                <table class="details-table">
                                    @if (selectedNode.CreationTime.HasValue)
                                    {
                                        <tr>
                                            <td class="label">Created:</td>
                                            <td class="value">@selectedNode.CreationTime.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                        </tr>
                                    }
                                    @if (selectedNode.LastWriteTime.HasValue)
                                    {
                                        <tr>
                                            <td class="label">Modified:</td>
                                            <td class="value">@selectedNode.LastWriteTime.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                        </tr>
                                    }
                                    @if (selectedNode.LastAccessTime.HasValue)
                                    {
                                        <tr>
                                            <td class="label">Accessed:</td>
                                            <td class="value">@selectedNode.LastAccessTime.Value.LocalDateTime.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                        </tr>
                                    }
                                </table>
                            </div>

                            <div class="detail-group">
                                <h4>@Localizer["AttributesTitle"]</h4>
                                <div class="attributes">
                                    @if (selectedNode.IsReadonly)
                                    {
                                        <span class="badge">Read-only</span>
                                    }
                                    @if (selectedNode.IsHidden)
                                    {
                                        <span class="badge">Hidden</span>
                                    }
                                    @if (selectedNode.IsArchive)
                                    {
                                        <span class="badge">Archive</span>
                                    }
                                    @if (selectedNode.IsSystem)
                                    {
                                        <span class="badge">System</span>
                                    }
                                    @if (selectedNode.IsOffline)
                                    {
                                        <span class="badge">Offline</span>
                                    }
                                    @if (selectedNode.IsTemporary)
                                    {
                                        <span class="badge">Temporary</span>
                                    }
                                    @if (!selectedNode.IsReadonly && !selectedNode.IsHidden && !selectedNode.IsArchive &&
                                                                !selectedNode.IsSystem && !selectedNode.IsOffline && !selectedNode.IsTemporary)
                                    {
                                        <span class="badge">None</span>
                                    }
                                </div>
                            </div>

                            <div class="detail-group">
                                <h4>@Localizer["TechnicalDetailsTitle"]</h4>
                                <table class="details-table">
                                    <tr>
                                        <td class="label">Stream ID:</td>
                                        <td class="value">@selectedNode.StreamId</td>
                                    </tr>
                                </table>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <p>@Localizer["SelectDocumentToView"]</p>
                </div>
            }
        </div>
    </div>
</div>
